[global]
    monitor = 1
    follow = none

    width = 350
    height = 300
    origin = top-right
    offset = 10x10

    notification_limit = 5

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 4

    indicate_hidden = yes
    separator_height = 2
    padding = 10
    horizontal_padding = 10
    frame_width = 2
    frame_color = "#3f3f46"
    separator_color = frame
    highlight = "#fafafa"
    gap_size = 6
    sort = yes

    font = JetBrainsMono Nerd Font 10
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    stack_duplicates = true
    show_indicators = yes

    enable_recursive_icon_lookup = true
    icon_theme = Papirus
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_corner_radius = 4

    corner_radius = 10

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#18181b"
    foreground = "#fafafa"
    timeout = 4

[urgency_normal]
    background = "#18181b"
    foreground = "#fafafa"
    timeout = 6

[urgency_critical]
    background = "#18181b"
    foreground = "#fafafa"
    frame_color = "#71717a"
    timeout = 0
